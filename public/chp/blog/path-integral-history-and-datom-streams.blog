             "Computation as Dimensional Expansion and Compression"]]
           [:li
            [:a {:href "/blog/ast-higher-dimensional-datom-streams.blog"}
             "AST as Higher Dimensional Datom Streams"]]
           [:li
            [:a {:href "/blog/process-calculus-causal-categories-datom-interpreters.blog"}
             "From pi-Calculus to Causal Categories: Interpreters as Functors"]]]]]]} 
