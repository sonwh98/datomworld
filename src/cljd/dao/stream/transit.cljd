(ns dao.stream.transit
  "Transit JSON serialization for stream link messages on ClojureDart.

   Mirrors the JVM and ClojureScript wrappers by delegating to
   `datomworld.transit`."
  (:require
    ["dart:core" StringBuffer]
    [datomworld.transit :as transit]))


(defn encode
  [msg]
  (let [buf (StringBuffer.)]
    (transit/write (transit/writer buf :json) msg)
    (.toString buf)))


(defn decode
  [s]
  (transit/read (transit/reader s :json) s))
